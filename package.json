{
  "name": "deeplake-plugin",
  "version": "0.3.7",
  "type": "module",
  "description": "DeepLake Memory — cloud-backed persistent shared memory for AI agents",
  "keywords": [
    "openclaw",
    "memory",
    "deeplake",
    "agent",
    "persistent-memory",
    "shared-memory"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/activeloopai/plur1bus"
  },
  "homepage": "https://deeplake.ai",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "deeplake-plugin",
      "minHostVersion": ">=2026.3.22"
    },
    "compat": {
      "pluginApi": ">=1.0.0"
    },
    "build": {
      "openclawVersion": "2026.3.22"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
