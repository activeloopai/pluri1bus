{
  "name": "plur1bus",
  "version": "0.1.0",
  "type": "module",
  "description": "Plur1bus — cloud-backed persistent memory for AI agents, powered by DeepLake",
  "keywords": ["openclaw", "memory", "deeplake", "agent", "persistent-memory", "shared-memory"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/activeloopai/plur1bus"
  },
  "homepage": "https://deeplake.ai",
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "install": {
      "npmSpec": "plur1bus",
      "minHostVersion": ">=2026.3.22"
    },
    "compat": {
      "pluginApi": ">=1.0.0"
    },
    "build": {
      "openclawVersion": "2026.3.22"
    }
  },
  "files": ["dist", "openclaw.plugin.json"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
