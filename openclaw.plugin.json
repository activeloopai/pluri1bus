{
  "id": "deeplake-memory",
  "kind": "memory",
  "name": "DeepLake Memory",
  "description": "Cloud-backed agent memory powered by DeepLake — vector search, BM25, and hybrid retrieval with auto-capture and auto-recall",
  "uiHints": {
    "mode": {
      "label": "Backend Mode",
      "placeholder": "auto"
    },
    "apiKey": {
      "label": "DeepLake API Key",
      "sensitive": true,
      "placeholder": "dl_xxx"
    },
    "apiUrl": {
      "label": "API URL",
      "advanced": true,
      "placeholder": "https://api.deeplake.ai"
    },
    "workspaceId": {
      "label": "Workspace ID",
      "placeholder": "default"
    },
    "mountPath": {
      "label": "FUSE Mount Path (CLI mode)",
      "advanced": true,
      "placeholder": "~/agent-memory"
    },
    "autoCapture": {
      "label": "Auto-Capture"
    },
    "autoRecall": {
      "label": "Auto-Recall"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["auto", "sdk", "cli"],
        "description": "auto = detect FUSE mount, fall back to SDK"
      },
      "apiKey": { "type": "string" },
      "apiUrl": { "type": "string" },
      "workspaceId": { "type": "string" },
      "mountPath": { "type": "string" },
      "autoCapture": { "type": "boolean" },
      "autoRecall": { "type": "boolean" }
    }
  }
}
